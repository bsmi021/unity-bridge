{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unity-bridge.local/schemas/coverage-registry.schema.json",
  "title": "Unity API coverage registry",
  "type": "object",
  "required": ["schema_version", "records"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "1.0" },
    "snapshot": {
      "type": "object",
      "required": ["sha256", "unity_version"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "unity_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol_id", "classification", "rationale", "proof"],
        "properties": {
          "symbol_id": { "type": "string", "minLength": 1 },
          "classification": {
            "enum": ["typed", "generic", "public_unwrapped", "no_public_api", "external_dependency", "obsolete", "explicit_non_goal"]
          },
          "rationale": { "type": "string", "minLength": 1 },
          "proof": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
